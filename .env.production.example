# Production environment – copy to .env.production and fill values.
# Do not commit .env.production (secrets). This file is the template.

NODE_ENV=production

# Required: JWT / session signing (use a long random string)
JWT_SECRET=

# Server
PORT=3000

# Public URL (דומיין מלא – אם מוגדר, OAuth/Analytics ישתמשו בו)
# Required for production: set to your live domain so the built frontend gets correct analytics and OAuth URLs.
# BASE_URL=https://megatoto.net
# BASE_URL=https://worldcup.example.com

# CORS: required in production (comma-separated). Must include the site origin(s) users use in the browser.
# ALLOWED_ORIGINS=https://megatoto.net,https://www.megatoto.net

# Database: leave empty for SQLite (./data/worldcup.db). Do not set DATABASE_URL in production — MySQL is not supported in this release.
# DATABASE_URL=

# OAuth (optional – leave empty if using local login only)
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=

# Admin: if set, users must enter this code to access admin panel
# ADMIN_SECRET=

# Super admin usernames (comma-separated)
# SUPER_ADMIN_USERNAMES=Yoven!,Yoven

# HTTPS behind reverse proxy: set to 1 for sameSite=lax when same-origin
# SAME_SITE_LAX_SAME_ORIGIN=1

# Agent commission % of site fee (0–100)
# AGENT_COMMISSION_PERCENT_OF_FEE=50

# Optional: built-in forge / AI
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# Optional: create first admin (scripts/create-admin.ts)
# CREATE_ADMIN_USERNAME=Yoven!
# CREATE_ADMIN_PASSWORD=
# CREATE_ADMIN_PHONE=0500000000
